class Solution {
public:
    int strStr(string haystack, string needle) {
        if (needle.size()==0) return 0; 
        if (needle.size()> haystack.size()) 
            return -1;
            int n = haystack.size();
        
        for ( int i = 0 ; i < n-needle.size()+1 ; i ++){
            int j = 0;
            while ( j < needle.size() && needle[j] == haystack[i+j] ){
                j++;
                
                }
if ( j == needle.size()){
            return i; } 
            
        };
        return -1;
    }
};
