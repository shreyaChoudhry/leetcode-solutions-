class Solution {
public:
    vector<int> findSubstring(string s, vector<string>& words) {
        vector<int> ans;

        int n = words.size();
        int m = words[0].size();
        int total = n * m;

        unordered_map<string, int> mp;
        for (auto w : words) mp[w]++;

        for (int i = 0; i < m; i++) {
            int left = i, count = 0;
            unordered_map<string, int> seen;

            for (int j = i; j + m <= s.size(); j += m) {

                string word = s.substr(j, m);

                if (mp.count(word)) {
                    seen[word]++;
                    count++;

                    while (seen[word] > mp[word]) {
                        string leftWord = s.substr(left, m);
                        seen[leftWord]--;
                        left += m;
                        count--;
                    }

                    if (count == n) {
                        ans.push_back(left);
                    }

                } else {
                    seen.clear();
                    count = 0;
                    left = j + m;
                }
            }
        }

        return ans;
    }
};
