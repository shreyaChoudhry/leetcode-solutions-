class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        set<char> CharSet;
        int maxLen=0;
        int left =0;
         for ( int right = 0 ; right < s.length(); right++){
             while ( CharSet.count(s[right])){
                CharSet.erase(s[left]);
                left++;
             }

            CharSet.insert(s[right]);
            maxLen = max(maxLen, right - left + 1);

         }
         return maxLen;
    }


};
